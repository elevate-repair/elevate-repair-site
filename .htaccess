RewriteEngine On

# Legacy subdir renames (must come first)
RewriteRule ^dishwasher-repair-denver/(.*)$ /dishwasher-repair/$1 [R=301,L]
RewriteRule ^dryer-repair-denver/(.*)$      /dryer-repair/$1      [R=301,L]
RewriteRule ^fridge-repair-denver/(.*)$     /fridge-repair/$1     [R=301,L]
RewriteRule ^oven-repair-denver/(.*)$       /oven-repair/$1       [R=301,L]
RewriteRule ^washer-repair-denver/(.*)$     /washer-repair/$1     [R=301,L]

# Redirect all .html URLs to clean URLs
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/([^.]+)\.html[\s?] [NC]
RewriteRule ^(.+)\.html$ /$1 [R=301,L]
